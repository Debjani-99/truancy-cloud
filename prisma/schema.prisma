generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  firstName    String
  lastName     String
  email        String   @unique
  role         Role
  countyId     String?
  schoolId     String?
  createdAt    DateTime @default(now())
  passwordHash String
  uploads      Upload[]
  county       County?  @relation(fields: [countyId], references: [id])
  school       School?  @relation(fields: [schoolId], references: [id])

  @@index([countyId])
  @@index([schoolId])
}

model County {
  id         String   @id @default(uuid())
  name       String   @unique
  schools    School[]
  courtUsers User[]
}

model School {
  id                String             @id @default(uuid())
  name              String
  countyId          String
  attendanceReports AttendanceReport[]
  county            County             @relation(fields: [countyId], references: [id])
  students          Student[]
  uploads           Upload[]
  users             User[]

  @@unique([countyId, name])
  @@index([countyId])
}

model Student {
  id         Int                @id @default(autoincrement())
  schoolId   String
  studentRef String?
  firstName  String
  lastName   String
  createdAt  DateTime           @default(now())
  records    AttendanceRecord[]
  school     School             @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, studentRef])
}

model AttendanceReport {
  id         Int                @id @default(autoincrement())
  uploadId   String             @unique
  schoolId   String
  schoolYear String
  createdAt  DateTime           @default(now())
  records    AttendanceRecord[]
  school     School             @relation(fields: [schoolId], references: [id])
  upload     Upload             @relation(fields: [uploadId], references: [id])
}

model AttendanceRecord {
  id                  Int              @id @default(autoincrement())
  reportId            Int
  studentId           Int
  excusedHours        Float
  unexcusedHours      Float
  medicalExcusedHours Float
  suspensionHours     Float
  totalAbsHours       Float
  addedHours          Float
  schoolYear          String
  report              AttendanceReport @relation(fields: [reportId], references: [id])
  student             Student          @relation(fields: [studentId], references: [id])

  @@unique([studentId, schoolYear])
}

model Upload {
  id           String            @id @default(uuid())
  filename     String
  storageKey   String
  fileSize     Int
  mimeType     String
  status       UploadStatus      @default(PENDING)
  schoolId     String
  uploadedAt   DateTime          @default(now())
  errorMessage String?
  uploadedById String
  report       AttendanceReport?
  school       School            @relation(fields: [schoolId], references: [id])
  uploadedBy   User              @relation(fields: [uploadedById], references: [id])

  @@index([schoolId])
  @@index([uploadedById])
}

enum Role {
  ADMIN
  COURT
  SCHOOL
}

enum UploadStatus {
  PENDING
  PROCESSING
  PARSED
  FAILED
  REVIEW
}
